// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  // provider = "sqlite"
  // url      = "file:./dev.db"
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Master Data Models
model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Color {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  hexCode   String? // For display purposes
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productColors ProductColor[]

  @@map("colors")
}

model Size {
  id        Int      @id @default(autoincrement())
  value     Int      @unique // Size number (36, 37, 38, etc.)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productSizes ProductSize[]

  @@map("sizes")
}

model Brand {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?
  logo        String? // URL to brand logo
  website     String? // Brand website URL
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("brands")
}

// Product Models
model Product {
  id            Int      @id @default(autoincrement())
  name          String
  slug          String   @unique
  description   String?
  price         Float
  originalPrice Float?
  thumbnailUrl  String? // Main product thumbnail for quick display
  isNew         Boolean  @default(false)
  isOnSale      Boolean  @default(false)
  isActive      Boolean  @default(true)
  weight        Float? // in grams
  dimensions    String? // JSON string for length, width, height
  material      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  brandId Int?
  brand   Brand? @relation(fields: [brandId], references: [id])

  galleryImages ProductImage[] @relation("ProductGallery")
  colors        ProductColor[]
  sizes         ProductSize[]
  reviews       Review[]
  orderItems    OrderItem[]

  @@map("products")
}

model ProductImage {
  id           Int      @id @default(autoincrement())
  url          String
  altText      String?
  caption      String? // Optional caption for gallery display
  displayOrder Int      @default(0) // Order in gallery
  createdAt    DateTime @default(now())

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade, name: "ProductGallery")

  @@map("product_images")
}

model ProductColor {
  id Int @id @default(autoincrement())

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  colorId Int
  color   Color @relation(fields: [colorId], references: [id])

  @@unique([productId, colorId])
  @@map("product_colors")
}

model ProductSize {
  id    Int @id @default(autoincrement())
  stock Int @default(0)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sizeId Int
  size   Size @relation(fields: [sizeId], references: [id])

  @@unique([productId, sizeId])
  @@map("product_sizes")
}

// Customer and Order Models
model Customer {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders  Order[]
  reviews Review[]

  @@map("customers")
}

model Order {
  id              Int         @id @default(autoincrement())
  orderNumber     String      @unique
  status          OrderStatus @default(PENDING)
  totalAmount     Float
  shippingCost    Float       @default(0)
  notes           String?
  shippingAddress String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id       Int    @id @default(autoincrement())
  quantity Int
  price    Float
  size     Int
  color    String

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// Review System
model Review {
  id         Int      @id @default(autoincrement())
  rating     Int // 1-5 stars
  comment    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  @@map("reviews")
}

// Enums
enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
